# ── Function App / Backend ─────────────────────────────────────────
DATABASE_URL=postgresql://cadvisor_admin:PASSWORD@cadvisor-pg-XXXX.postgres.database.azure.com:5432/compliance_advisor?sslmode=require
KEY_VAULT_URL=https://cadvisor-kv-XXXX.vault.azure.net/
AZURE_OPENAI_ENDPOINT=https://cadvisor-oai-XXXX.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://cadvisor-fd-XXXX.services.ai.azure.com/api/projects/compliance-advisor
AZURE_FOUNDRY_AGENT_ID=
AZURE_FOUNDRY_MODEL_DEPLOYMENT=gpt-4o
ALLOWED_TENANT_IDS=

# ── Collector ─────────────────────────────────────────────────────
CLIENT_ID=                          # Multi-tenant app registration client ID
CLIENT_SECRET=                      # Client secret for the app registration
TENANT_ID=                          # Target GCC tenant GUID
AGENCY_ID=                          # Logical agency identifier
DEPARTMENT=                         # Department name for dashboard filtering
DISPLAY_NAME=                       # Human-readable tenant name
FUNCTION_APP_URL=https://cadvisor-func-prod.azurewebsites.net/api/ingest
FUNCTION_APP_KEY=                   # Function-level API key
AUDIT_LOG_DAYS=1                    # Days of audit log history to query (default: 1)
