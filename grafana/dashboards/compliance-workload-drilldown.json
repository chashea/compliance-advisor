      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "orientation": "auto",
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT t.display_name AS tenant_name, ec.status, COUNT(*)::int AS total_cases FROM ediscovery_cases ec JOIN tenants t ON t.tenant_id = ec.tenant_id WHERE ec.snapshot_date = (SELECT MAX(snapshot_date) FROM ediscovery_cases) GROUP BY t.display_name, ec.status ORDER BY total_cases DESC;",
          "refId": "A"
        }
      ],
      "title": "eDiscovery Cases by Tenant/Status",
      "type": "barchart"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "pieType": "pie",
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT status, COUNT(*)::int AS total FROM subject_rights_requests WHERE snapshot_date = (SELECT MAX(snapshot_date) FROM subject_rights_requests) GROUP BY status ORDER BY total DESC;",
          "refId": "A"
        }
      ],
      "title": "Subject Rights Requests by Status",
      "type": "piechart"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT t.display_name AS tenant_name, COALESCE(s.label_count, 0) AS sensitivity_labels, COALESCE(r.label_count, 0) AS retention_labels FROM tenants t LEFT JOIN (SELECT tenant_id, COUNT(*)::int AS label_count FROM sensitivity_labels WHERE snapshot_date = (SELECT MAX(snapshot_date) FROM sensitivity_labels) GROUP BY tenant_id) s ON s.tenant_id = t.tenant_id LEFT JOIN (SELECT tenant_id, COUNT(*)::int AS label_count FROM retention_labels WHERE snapshot_date = (SELECT MAX(snapshot_date) FROM retention_labels) GROUP BY tenant_id) r ON r.tenant_id = t.tenant_id ORDER BY sensitivity_labels ASC, retention_labels ASC, tenant_name;",
          "refId": "A"
        }
      ],
      "title": "Label Coverage Gap by Tenant",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "id": 4,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT title, severity, status, policy_name, created, tenant_name FROM (SELECT ia.title, ia.severity, ia.status, ia.policy_name, ia.created, t.display_name AS tenant_name FROM irm_alerts ia JOIN tenants t ON t.tenant_id = ia.tenant_id WHERE ia.snapshot_date = (SELECT MAX(snapshot_date) FROM irm_alerts) AND (ia.policy_name ILIKE '%AI%' OR ia.title ILIKE '%Copilot%' OR ia.title ILIKE '%ChatGPT%') ORDER BY ia.created DESC) s LIMIT 25;",
          "refId": "A"
        }
      ],
      "title": "AI-Related IRM Alerts",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "id": 5,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT display_name, policy_type, status, review_pending_count, tenant_name FROM (SELECT cc.display_name, cc.policy_type, cc.status, cc.review_pending_count, t.display_name AS tenant_name FROM comm_compliance_policies cc JOIN tenants t ON t.tenant_id = cc.tenant_id WHERE cc.snapshot_date = (SELECT MAX(snapshot_date) FROM comm_compliance_policies) ORDER BY cc.review_pending_count DESC, cc.display_name ASC) s LIMIT 25;",
          "refId": "A"
        }
      ],
      "title": "Communication Compliance Policy Queue",
      "type": "table"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
