          "rawSql": "SELECT ct.snapshot_date::timestamp AS \"time\", COALESCE((to_jsonb(ct)->>'dlp_alerts')::int, (to_jsonb(ct)->>'dlp')::int, 0) AS \"DLP Alerts\", COALESCE((to_jsonb(ct)->>'audit_records')::int, (to_jsonb(ct)->>'audit')::int, 0) AS \"Audit Records\", COALESCE((to_jsonb(ct)->>'ediscovery_cases')::int, (to_jsonb(ct)->>'ediscovery')::int, 0) AS \"eDiscovery Cases\" FROM compliance_trend ct WHERE ct.department IS NULL ORDER BY ct.snapshot_date;",
